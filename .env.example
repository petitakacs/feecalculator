DATABASE_URL="mysql://user:password@localhost:3306/feecalculator"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
# AES-256 key for encrypting 2FA secrets at rest (32 bytes = 64 hex chars)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="your-64-hex-char-key-here"

# Seed passwords (dev/test only — never run seed in production)
SEED_ADMIN_PASSWORD="ChangeMe!Admin1"
SEED_MANAGER_PASSWORD="ChangeMe!Manager1"
SEED_LEAD_PASSWORD="ChangeMe!Lead1"

# Email notifications (optional — leave blank to disable)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Fee Calculator <noreply@example.com>"
