// All percentages stored as decimals (e.g., 0.039 for 3.9%)
// All monetary amounts stored as integers (HUF) to avoid float issues

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─── Location ────────────────────────────────────────────────────────────────

model Location {
  id                   String    @id @default(cuid())
  name                 String    @unique
  address              String?
  serviceChargePercent Decimal?
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  employees         Employee[]
  periods           MonthlyPeriod[]
  loanEntries       MonthlyEmployeeEntry[] @relation("WorkingLocation")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id                   String           @id @default(cuid())
  name                 String
  email                String           @unique
  passwordHash         String
  role                 Role             @default(STORE_MANAGER)
  active               Boolean          @default(true)
  twoFactorEnabled     Boolean          @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  auditLogs            AuditLog[]
  approvals            PeriodApproval[]
  twoFactorTokens      TwoFactorToken[]
}

model TwoFactorToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Role {
  ADMIN
  BUSINESS_UNIT_LEAD
  STORE_MANAGER
  FINANCE_VIEWER
  PAYROLL_EXPORT_USER
}

// ─── Positions ────────────────────────────────────────────────────────────────

model Position {
  id                       String                 @id @default(cuid())
  name                     String                 @unique
  multiplier               Decimal
  eligibleForServiceCharge Boolean                @default(true)
  defaultOvertimeRule      String?
  minHourlyServiceCharge   Int?
  maxHourlyServiceCharge   Int?
  active                   Boolean                @default(true)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  employees                Employee[]
  seasonPositionRules      SeasonPositionRule[]
  monthlyEntries           MonthlyEmployeeEntry[]
  variations               PositionVariation[]
}

model PositionVariation {
  id              String   @id @default(cuid())
  positionId      String
  position        Position @relation(fields: [positionId], references: [id])
  name            String   // e.g. "Diák", "Új belépő"
  multiplierDelta Decimal  // additive delta from base, e.g. -0.10
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employees Employee[]

  @@unique([positionId, name])
  @@index([positionId])
}

// ─── Employees ────────────────────────────────────────────────────────────────

model Employee {
  id                       String                 @id @default(cuid())
  name                     String
  active                   Boolean                @default(true)
  positionId               String
  position                 Position               @relation(fields: [positionId], references: [id])
  variationId              String?
  variation                PositionVariation?     @relation(fields: [variationId], references: [id])
  baseSalaryType           SalaryType
  baseSalaryAmount         Int
  eligibleForServiceCharge Boolean                @default(true)
  startDate                DateTime
  endDate                  DateTime?
  locationId               String?
  location                 Location?              @relation(fields: [locationId], references: [id])
  notes                    String?                @db.Text
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  monthlyEntries           MonthlyEmployeeEntry[]
  extraTasks               MonthlyExtraTask[]

  @@index([positionId])
  @@index([locationId])
  @@index([variationId])
}

enum SalaryType {
  HOURLY
  MONTHLY
}

// ─── Seasons ──────────────────────────────────────────────────────────────────

model Season {
  id                       String               @id @default(cuid())
  name                     String
  startDate                DateTime
  endDate                  DateTime
  referenceMode            ReferenceMode        @default(SALES_BASED)
  manualWaiterTargetHourly Int?
  minAllowedVariance       Decimal?
  maxAllowedVariance       Decimal?
  active                   Boolean              @default(true)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  periods                  MonthlyPeriod[]
  positionRules            SeasonPositionRule[]
}

enum ReferenceMode {
  SALES_BASED
  MANUAL_TARGET
  SALES_BASED_WITH_LIMITS
}

model SeasonPositionRule {
  id         String   @id @default(cuid())
  seasonId   String
  season     Season   @relation(fields: [seasonId], references: [id])
  positionId String
  position   Position @relation(fields: [positionId], references: [id])
  multiplier Decimal
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([seasonId, positionId])
  @@index([seasonId])
  @@index([positionId])
}

model BusinessRule {
  id                   String    @id @default(cuid())
  effectiveFrom        DateTime
  effectiveTo          DateTime?
  serviceChargePercent Decimal
  employeeContribution Decimal
  notes                String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// ─── Monthly Periods ──────────────────────────────────────────────────────────

model MonthlyPeriod {
  id                        String                 @id @default(cuid())
  month                     Int
  year                      Int
  // locationId null = legacy / location-agnostic period
  locationId                String?
  location                  Location?              @relation(fields: [locationId], references: [id])
  seasonId                  String
  season                    Season                 @relation(fields: [seasonId], references: [id])
  openingBalance            Int                    @default(0)
  collectedServiceCharge    Int                    @default(0)
  distributableBalance      Int                    @default(0)
  targetDistributionTotal   Int                    @default(0)
  approvedDistributionTotal Int                    @default(0)
  closingBalance            Int                    @default(0)
  status                    PeriodStatus           @default(DRAFT)
  notes                     String?                @db.Text
  lockedAt                  DateTime?
  lockedBy                  String?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  entries                   MonthlyEmployeeEntry[]
  approvals                 PeriodApproval[]
  auditLogs                 AuditLog[]
  extraTasks                MonthlyExtraTask[]

  // Per-location uniqueness: one period per location per month/year
  // (NULL locationId rows don't conflict with each other in MySQL)
  @@unique([month, year, locationId])
  @@index([seasonId])
  @@index([locationId])
}

enum PeriodStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  CLOSED
}

// ─── Monthly Entries ──────────────────────────────────────────────────────────

model MonthlyEmployeeEntry {
  id                           String        @id @default(cuid())
  periodId                     String
  period                       MonthlyPeriod @relation(fields: [periodId], references: [id])
  employeeId                   String
  employee                     Employee      @relation(fields: [employeeId], references: [id])
  // positionId can differ from employee.positionId for multi-role entries
  positionId                   String
  position                     Position      @relation(fields: [positionId], references: [id])
  // For loan / secondment: which location this entry is worked at
  workingLocationId            String?
  workingLocation              Location?     @relation("WorkingLocation", fields: [workingLocationId], references: [id])
  isLoanEntry                  Boolean       @default(false)
  // Optional label for multi-role entries, e.g. "Felszolgáló műszak"
  entryLabel                   String?
  workedHours                  Decimal       @default(0)
  overtimeHours                Decimal       @default(0)
  netWaiterSales               Int?
  calculatedGrossServiceCharge Int?
  calculatedNetServiceCharge   Int?
  targetNetHourlyServiceCharge Int?
  targetServiceChargeAmount    Int?
  bonus                        Int           @default(0)
  overtimePayment              Int           @default(0)
  manualCorrection             Int           @default(0)
  manualCorrectionReason       String?
  finalApprovedAmount          Int?
  notes                        String?       @db.Text
  overrideFlag                 Boolean       @default(false)
  overrideReason               String?
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt

  // Multi-role: same employee can have multiple entries per period if positionId differs
  @@unique([periodId, employeeId, positionId])
  @@index([periodId])
  @@index([employeeId])
  @@index([positionId])
  @@index([workingLocationId])
}

// ─── Extra Task Types ─────────────────────────────────────────────────────────

enum ExtraBonusType {
  FIXED_AMOUNT
  HOURLY_RATE
}

model ExtraTaskType {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  bonusType   ExtraBonusType
  // Ft per month (FIXED_AMOUNT) or Ft per hour (HOURLY_RATE)
  bonusAmount Int
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  assignments MonthlyExtraTask[]
}

model MonthlyExtraTask {
  id              String        @id @default(cuid())
  periodId        String
  period          MonthlyPeriod @relation(fields: [periodId], references: [id])
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id])
  extraTaskTypeId String
  extraTaskType   ExtraTaskType @relation(fields: [extraTaskTypeId], references: [id])
  // Only relevant for HOURLY_RATE tasks
  hours           Decimal?
  // Computed: bonusAmount (FIXED) or bonusAmount × hours (HOURLY)
  amount          Int
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([periodId, employeeId, extraTaskTypeId])
  @@index([periodId])
  @@index([employeeId])
  @@index([extraTaskTypeId])
}

// ─── Approvals & Audit ────────────────────────────────────────────────────────

model PeriodApproval {
  id        String         @id @default(cuid())
  periodId  String
  period    MonthlyPeriod  @relation(fields: [periodId], references: [id])
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  action    ApprovalAction
  comment   String?
  createdAt DateTime       @default(now())

  @@index([periodId])
  @@index([userId])
}

enum ApprovalAction {
  SUBMITTED
  APPROVED
  REJECTED
  REOPENED
  CLOSED
}

model AuditLog {
  id         String         @id @default(cuid())
  periodId   String?
  period     MonthlyPeriod? @relation(fields: [periodId], references: [id])
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime       @default(now())

  @@index([periodId])
  @@index([userId])
}

model ImportLog {
  id         String   @id @default(cuid())
  periodId   String
  fileName   String
  rowCount   Int
  errors     Json?
  importedBy String
  createdAt  DateTime @default(now())
}
