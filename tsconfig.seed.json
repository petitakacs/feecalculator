{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "ignoreDeprecations": "6.0"
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["prisma/seed.ts"]
}